# integration/.env.example
# VIGIL-IA · CORFO Semilla Inicia 25INI-282394
#
# Variables compartidas por los tres componentes (inferencia, backend,
# frontend) al correr integrados en el nodo Jetson Orin. Copiar como .env
# y ajustar antes del despliegue en terreno. No versionar el .env real.

# --- Rutas compartidas (todas relativas a la raíz del repo) ---
VIGILIA_DB_PATH=./data/vigilia_events.db
VIGILIA_MODEL_PATH=./runs/export/best.engine
VIGILIA_RTSP_SOURCE=rtsp://192.168.1.100/stream1

# --- Backend (backend/config.py) ---
VIGILIA_JWT_SECRET=change-me-before-production
VIGILIA_JWT_EXPIRE_MIN=480

# --- Puertos ---
VIGILIA_BACKEND_PORT=8000
VIGILIA_FRONTEND_PORT=80
